# Database
DATABASE_URL=postgresql+asyncpg://driftguard:driftguard@localhost:5432/driftguard

# Redis
REDIS_URL=redis://localhost:6379

# Docker
DOCKER_SOCKET=unix:///var/run/docker.sock
COMPOSE_FILE_PATH=./docker-compose.yml

# API
API_HOST=0.0.0.0
API_PORT=8000

# Polling
POLL_INTERVAL_SECONDS=60
